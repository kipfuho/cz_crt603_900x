<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="button">
        <item name="android:background">@drawable/nav_bt_selector</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="buttonStyle">
        <item name="android:background">@drawable/nav_bt_selector</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">250dp</item>
        <item name="android:layout_height">110dp</item>
    </style>

    <style name="CZ_buttonStyle">
        <item name="android:background">@drawable/nav_bt_selector</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:layout_marginRight">40dp</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">130dp</item>
    </style>

    <style name="buttonStyle_face">
        <item name="android:background">@drawable/nav_bt_selector</item>
        <item name="android:layout_marginRight">40dp</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">250dp</item>
        <item name="android:layout_height">130dp</item>
    </style>

    <style name="OCR_buttonStyle">
        <item name="android:background">@drawable/nav_bt_selector</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">80dp</item>
    </style>

    <style name="CustomDialog" parent="android:style/Theme.Dialog">
        <!-- Background color and transparency -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- Whether to remove title -->
        <item name="android:windowNoTitle">true</item>
        <!-- Whether to remove border -->
        <item name="android:windowFrame">@null</item>
        <!-- Whether to float above the activity -->
        <item name="android:windowIsFloating">true</item>
        <!-- Whether to blur -->
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="idcard_tv_style">
        <item name="android:textSize">30dp</item>
        <item name="android:layout_margin">20dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="idcard_name_title_tv">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#168dcf</item>
    </style>

    <style name="idcard_name_tv">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#393939</item>
    </style>

    <style name="device_item_tv_style">
        <item name="android:textSize">25dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginLeft">10dp</item>
        <item name="android:layout_marginRight">10dp</item>
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="self_test_right_ll">
        <item name="android:gravity">center</item>
        <item name="android:layout_marginLeft">20dp</item>
        <item name="android:layout_marginTop">15dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="self_test_ll">
        <item name="android:gravity">center</item>
        <item name="android:layout_marginTop">15dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="self_test_right_tv">
        <item name="android:layout_gravity">left|center_vertical</item>
        <item name="android:textSize">20dp</item>
        <item name="android:layout_marginLeft">70dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="self_test_tv">
        <item name="android:layout_gravity">left|center_vertical</item>
        <item name="android:textSize">20dp</item>
        <item name="android:layout_marginLeft">20dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_width">400dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="self_test_iv">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
    </style>

    <style name="setting_tv">
        <item name="android:textSize">20dp</item>
        <item name="android:layout_width">180dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="setting_sp">
        <item name="android:layout_marginLeft">20dp</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginRight">10dp</item>
    </style>

    <style name="setting_ll">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="setting_button">
        <item name="android:layout_marginLeft">20dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">50dp</item>
    </style>

    <style name="ocr_rr">
        <item name="android:layout_margin">2dp</item>
        <item name="android:padding">2dp</item>
        <item name="android:background">@drawable/camera_view_frame</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="button_style">
        <item name="android:gravity">center</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20dp</item>
    </style>

</resources>
