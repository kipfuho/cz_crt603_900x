<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal">

  <!-- Left: Camera preview + captured image -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:padding="12dp"
    android:orientation="vertical">

    <ImageView
      android:id="@+id/current_iv"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:layout_marginTop="8dp"
      android:background="#1a1a1a"
      android:scaleType="centerInside" />

    <RelativeLayout
      android:id="@+id/cameraView"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:background="#000000" />

  </LinearLayout>

  <!-- Right: Controls + MRZ result -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:padding="16dp"
    android:orientation="vertical">

    <!-- Buttons -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <Button
        android:id="@+id/takePictureLightBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Take picture (Light)" />

      <Button
        android:id="@+id/takePictureIrBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Take picture (IR)" />

      <Button
        android:id="@+id/takePictureUvBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Take picture (UV)" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="CARD TYPE"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"/>

      <Spinner
        android:id="@+id/spinnerCardType"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        android:textSize="9sp" />

      <Button
        android:id="@+id/singleReadBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Scan once" />

      <Button
        android:id="@+id/loopReadBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Loop scan" />



    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <Button
        android:id="@+id/btSimKiosk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SIM Kiosk" />

      <Button
        android:id="@+id/exitBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exit" />

    </LinearLayout>

    <!-- Status -->
    <TextView
      android:id="@+id/resultTv"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="Initialising…"
      android:textColor="#333333"
      android:textSize="14sp" />

    <!-- MRZ result area -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:text="MRZ"
      android:textColor="#888888"
      android:textSize="12sp" />

    <TextView
      android:id="@+id/result_lv"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:padding="10dp"
      android:background="#F3F4F3"
      android:fontFamily="monospace"
      android:textColor="#111111"
      android:textSize="13sp" />

  </LinearLayout>

</LinearLayout>