<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal"
  android:background="#0D0F0E">

  <!-- ═══════════════════════════════════════
       LEFT PANEL — connection + transport
       ═══════════════════════════════════════ -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingBottom="8dp">
      <View android:layout_width="4dp" android:layout_height="24dp"
        android:background="#F0A500" android:layout_marginEnd="8dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SIM KIOSK" android:textColor="#F0A500" android:textSize="16sp"
        android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.12"/>
      <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"
        android:layout_marginStart="10dp" android:background="#2A2E2C"/>
    </LinearLayout>

    <!-- Connection panel -->
    <LinearLayout
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:background="#141918"
      android:padding="8dp" android:layout_marginBottom="8dp">

      <!-- PORT + BAUD -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="5dp">
        <TextView android:layout_width="34dp" android:layout_height="wrap_content"
          android:text="PORT" android:textColor="#6B7573" android:textSize="9sp"
          android:fontFamily="monospace"/>
        <Spinner android:id="@+id/spinnerSimPort" android:layout_width="0dp"
          android:layout_height="32dp" android:layout_weight="1"
          android:layout_marginEnd="6dp" android:background="#1E2422"
          android:popupBackground="#1E2422"/>
        <TextView android:layout_width="34dp" android:layout_height="wrap_content"
          android:text="BAUD" android:textColor="#6B7573" android:textSize="9sp"
          android:fontFamily="monospace"/>
        <Spinner android:id="@+id/spinnerSimBaud" android:layout_width="0dp"
          android:layout_height="32dp" android:layout_weight="1"
          android:background="#1E2422" android:popupBackground="#1E2422"/>
      </LinearLayout>

      <!-- ADDR + status + CONNECT/DISC -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="34dp" android:layout_height="wrap_content"
          android:text="ADDR" android:textColor="#6B7573" android:textSize="9sp"
          android:fontFamily="monospace"/>
        <Spinner android:id="@+id/spinnerSimAddr" android:layout_width="72dp"
          android:layout_height="32dp" android:layout_marginEnd="6dp"
          android:background="#1E2422" android:popupBackground="#1E2422"/>
        <TextView android:id="@+id/tvConnInfo" android:layout_width="0dp"
          android:layout_height="wrap_content" android:layout_weight="1"
          android:text="Not connected" android:textColor="#CF6679"
          android:textSize="9sp" android:fontFamily="monospace"
          android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnSimConnect" android:layout_width="wrap_content"
          android:layout_height="32dp" android:text="CONNECT"
          android:textColor="#0D0F0E" android:textSize="9sp"
          android:fontFamily="monospace" android:backgroundTint="#8EC97A"
          android:paddingStart="8dp" android:paddingEnd="8dp"
          android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnSimDisconnect" android:layout_width="wrap_content"
          android:layout_height="32dp" android:text="DISC."
          android:textColor="#E8EBE9" android:textSize="9sp"
          android:fontFamily="monospace" android:backgroundTint="#2A2E2C"
          android:paddingStart="8dp" android:paddingEnd="8dp"/>
      </LinearLayout>
    </LinearLayout>

    <!-- ICCID + Stock row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="6dp">
      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="3" android:orientation="vertical"
        android:background="#141918" android:padding="10dp" android:layout_marginEnd="5dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="ICCID" android:textColor="#6B7573" android:textSize="9sp"
          android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvIccid" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:text="—"
          android:textColor="#E8EBE9" android:textSize="12sp"
          android:fontFamily="monospace" android:layout_marginTop="2dp"/>
      </LinearLayout>
      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:background="#141918" android:padding="10dp" android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="STOCK" android:textColor="#6B7573" android:textSize="9sp"
          android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvStockLevel" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:text="—"
          android:textColor="#F0A500" android:textSize="20sp"
          android:fontFamily="monospace" android:textStyle="bold"
          android:layout_marginTop="2dp"/>
      </LinearLayout>
    </LinearLayout>

    <!-- Status -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:background="#141918"
      android:padding="8dp" android:layout_marginBottom="8dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="STATUS" android:textColor="#6B7573" android:textSize="9sp"
        android:fontFamily="monospace"/>
      <TextView android:id="@+id/tvSimStatus" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Initialising…"
        android:textColor="#8EC97A" android:textSize="10sp"
        android:fontFamily="monospace" android:layout_marginTop="2dp" android:maxLines="3"/>
    </LinearLayout>

    <!-- Section: DISPENSER -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
      android:text="DISPENSER" android:textColor="#6B7573" android:textSize="9sp"
      android:fontFamily="monospace" android:letterSpacing="0.15"
      android:layout_marginBottom="5dp"/>

    <!-- READ ICCID — primary CTA -->
    <Button android:id="@+id/btnReadIccid" android:layout_width="match_parent"
      android:layout_height="48dp" android:text="▶  READ ICCID"
      android:textColor="#0D0F0E" android:textSize="12sp"
      android:fontFamily="monospace" android:textStyle="bold"
      android:backgroundTint="#F0A500" android:layout_marginBottom="5dp"/>

    <!-- CHECK STOCK + DISPENSE -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="4dp">
      <Button android:id="@+id/btnCheckStock" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginEnd="4dp" android:text="CHECK STOCK"
        android:textColor="#F0A500" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
      <Button android:id="@+id/btnDispense" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginStart="4dp" android:text="⏏ DISPENSE"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
    </LinearLayout>

    <!-- PUSH TO GATE + FULL EJECT -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="4dp">
      <Button android:id="@+id/btnPushToGate" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginEnd="4dp" android:text="⏩ PUSH GATE"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
      <Button android:id="@+id/btnEjectFull" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginStart="4dp" android:text="⏭ FULL EJECT"
        android:textColor="#CF6679" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
    </LinearLayout>

    <!-- RETRACT + RECYCLE -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="4dp">
      <Button android:id="@+id/btnRetract" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginEnd="4dp" android:text="⏪ RETRACT"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
      <Button android:id="@+id/btnRecycle" android:layout_width="0dp"
        android:layout_height="42dp" android:layout_weight="1"
        android:layout_marginStart="4dp" android:text="♻ RECYCLE"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
    </LinearLayout>

    <!-- MOTOR BACKWARD + ENABLE/DISABLE ENTRY -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal">
      <Button android:id="@+id/btnMotorBackward" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginEnd="3dp" android:text="◀ MOTOR BWD"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
      <Button android:id="@+id/btnEnableEntry" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
        android:text="ENTRY ON" android:textColor="#8EC97A" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
      <Button android:id="@+id/btnDisableEntry" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:text="ENTRY OFF"
        android:textColor="#CF6679" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#1E2422"/>
    </LinearLayout>

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

    <Button android:id="@+id/btnSimBack" android:layout_width="match_parent"
      android:layout_height="36dp" android:text="← BACK"
      android:textColor="#6B7573" android:textSize="10sp"
      android:fontFamily="monospace" android:backgroundTint="#0D0F0E"
      android:onClick="finish"/>
  </LinearLayout>

  <!-- Divider -->
  <View android:layout_width="1dp" android:layout_height="match_parent"
    android:background="#1E2422"/>

  <!-- ═══════════════════════════════════════
       RIGHT PANEL — IC + reset + device + log
       ═══════════════════════════════════════ -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Section: IC CHIP -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:gravity="center_vertical" android:paddingBottom="6dp">
      <View android:layout_width="4dp" android:layout_height="16dp"
        android:background="#F0A500" android:layout_marginEnd="7dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="IC CHIP" android:textColor="#F0A500" android:textSize="10sp"
        android:fontFamily="monospace" android:letterSpacing="0.15"/>
    </LinearLayout>

    <!-- AUTO DETECT TYPE (full width) -->
    <Button android:id="@+id/btnAutoDetectType" android:layout_width="match_parent"
      android:layout_height="38dp" android:text="AUTO DETECT TYPE"
      android:textColor="#E8EBE9" android:textSize="9sp"
      android:fontFamily="monospace" android:backgroundTint="#141918"
      android:layout_marginBottom="4dp"/>

    <!-- COLD RST + WARM RST + DEACT -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="8dp">
      <Button android:id="@+id/btnSimColdReset" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginEnd="3dp" android:text="COLD RST"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnSimWarmReset" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
        android:text="WARM RST" android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnSimDeactivate" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:text="DEACT."
        android:textColor="#CF6679" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
    </LinearLayout>

    <!-- Section: RESET / INIT -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:gravity="center_vertical" android:paddingBottom="6dp">
      <View android:layout_width="4dp" android:layout_height="16dp"
        android:background="#F0A500" android:layout_marginEnd="7dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="RESET / INIT" android:textColor="#F0A500" android:textSize="10sp"
        android:fontFamily="monospace" android:letterSpacing="0.15"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="8dp">
      <Button android:id="@+id/btnResetEject" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginEnd="3dp" android:text="RST+EJECT"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnResetRecycle" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
        android:text="RST+RECYCLE" android:textColor="#CF6679" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnResetStay" android:layout_width="0dp"
        android:layout_height="38dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:text="RST STAY"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
    </LinearLayout>

    <!-- Section: DEVICE -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:gravity="center_vertical" android:paddingBottom="6dp">
      <View android:layout_width="4dp" android:layout_height="16dp"
        android:background="#3A7BFF" android:layout_marginEnd="7dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="DEVICE" android:textColor="#3A7BFF" android:textSize="10sp"
        android:fontFamily="monospace" android:letterSpacing="0.15"/>
    </LinearLayout>

    <!-- STATUS + SENSORS -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="3dp">
      <Button android:id="@+id/btnSimQueryStatus" android:layout_width="0dp"
        android:layout_height="36dp" android:layout_weight="1"
        android:layout_marginEnd="3dp" android:text="STATUS"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnSimQuerySensors" android:layout_width="0dp"
        android:layout_height="36dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:text="SENSORS"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
    </LinearLayout>

    <!-- SERIAL + CONFIG + FIRMWARE -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="3dp">
      <Button android:id="@+id/btnSimSerialNumber" android:layout_width="0dp"
        android:layout_height="36dp" android:layout_weight="1"
        android:layout_marginEnd="3dp" android:text="SERIAL"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnSimDeviceConfig" android:layout_width="0dp"
        android:layout_height="36dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
        android:text="CONFIG" android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
      <Button android:id="@+id/btnSimFirmware" android:layout_width="0dp"
        android:layout_height="36dp" android:layout_weight="1"
        android:layout_marginStart="3dp" android:text="FIRMWARE"
        android:textColor="#E8EBE9" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"/>
    </LinearLayout>

    <!-- BIN COUNTER (full width) -->
    <Button android:id="@+id/btnRecycleBinCount" android:layout_width="match_parent"
      android:layout_height="36dp" android:text="RECYCLE BIN COUNT"
      android:textColor="#E8EBE9" android:textSize="9sp"
      android:fontFamily="monospace" android:backgroundTint="#141918"
      android:layout_marginBottom="8dp"/>

    <!-- Section: LOG -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="4dp">
      <View android:layout_width="4dp" android:layout_height="16dp"
        android:background="#3A7BFF" android:layout_marginEnd="7dp"/>
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="COMMAND LOG"
        android:textColor="#3A7BFF" android:textSize="10sp"
        android:fontFamily="monospace" android:letterSpacing="0.15"/>
      <Button android:id="@+id/btnSimClearLog" android:layout_width="wrap_content"
        android:layout_height="28dp" android:text="CLEAR"
        android:textColor="#6B7573" android:textSize="9sp"
        android:fontFamily="monospace" android:backgroundTint="#141918"
        android:paddingStart="8dp" android:paddingEnd="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
      android:layout_weight="1" android:background="#0A0C0B" android:padding="2dp">
      <TextView android:id="@+id/tvSimLog" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:padding="8dp"
        android:textColor="#8EC97A" android:textSize="10sp"
        android:fontFamily="monospace" android:lineSpacingMultiplier="1.25"/>
    </ScrollView>

  </LinearLayout>

</LinearLayout>