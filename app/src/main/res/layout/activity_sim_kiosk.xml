<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal"
  android:background="#0D0F0E">

  <!-- ═══════════════════════════════════════════════════════════════
       LEFT PANEL — connection + card info + transport
       ═══════════════════════════════════════════════════════════════ -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingBottom="10dp">

      <View
        android:layout_width="4dp"
        android:layout_height="26dp"
        android:background="#F0A500"
        android:layout_marginEnd="10dp"/>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sim_kiosk"
        android:textColor="#F0A500"
        android:textSize="17sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"
        android:textStyle="bold"/>

      <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:background="#2A2E2C"/>

    </LinearLayout>

    <!-- ── Connection panel ─────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="#141918"
      android:padding="10dp"
      android:layout_marginBottom="8dp">

      <!-- Row 1: PORT + BAUD -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
          android:layout_width="36dp"
          android:layout_height="wrap_content"
          android:text="@string/port"
          android:textColor="#6B7573"
          android:textSize="11sp"
          android:fontFamily="monospace"/>

        <Spinner
          android:id="@+id/spinnerSimPort"
          android:layout_width="0dp"
          android:layout_height="34dp"
          android:layout_weight="1"
          android:layout_marginEnd="8dp"
          android:background="#1E2422"
          android:popupBackground="#1E2422"/>

        <TextView
          android:layout_width="36dp"
          android:layout_height="wrap_content"
          android:text="@string/baud"
          android:textColor="#6B7573"
          android:textSize="11sp"
          android:fontFamily="monospace"/>

        <Spinner
          android:id="@+id/spinnerSimBaud"
          android:layout_width="0dp"
          android:layout_height="34dp"
          android:layout_weight="1"
          android:background="#1E2422"
          android:popupBackground="#1E2422"/>

      </LinearLayout>

      <!-- Row 2: ADDR + status label + CONNECT / DISC buttons -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
          android:layout_width="36dp"
          android:layout_height="wrap_content"
          android:text="@string/addr"
          android:textColor="#6B7573"
          android:textSize="11sp"
          android:fontFamily="monospace"/>

        <Spinner
          android:id="@+id/spinnerSimAddr"
          android:layout_width="80dp"
          android:layout_height="34dp"
          android:layout_marginEnd="8dp"
          android:background="#1E2422"
          android:popupBackground="#1E2422"/>

        <TextView
          android:id="@+id/tvConnInfo"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/not_connected"
          android:textColor="#CF6679"
          android:textSize="11sp"
          android:fontFamily="monospace"
          android:layout_marginEnd="6dp"/>

        <Button
          android:id="@+id/btnSimConnect"
          android:layout_width="wrap_content"
          android:layout_height="34dp"
          android:text="@string/connect"
          android:textColor="#0D0F0E"
          android:textSize="11sp"
          android:fontFamily="monospace"
          android:backgroundTint="#8EC97A"
          android:paddingStart="10dp"
          android:paddingEnd="10dp"
          android:layout_marginEnd="4dp"/>

        <Button
          android:id="@+id/btnSimDisconnect"
          android:layout_width="wrap_content"
          android:layout_height="34dp"
          android:text="@string/disconnect"
          android:textColor="#E8EBE9"
          android:textSize="11sp"
          android:fontFamily="monospace"
          android:backgroundTint="#2A2E2C"
          android:paddingStart="10dp"
          android:paddingEnd="10dp"/>

      </LinearLayout>

    </LinearLayout>

    <!-- ── ICCID + Stock level row ──────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:baselineAligned="false"
      android:orientation="horizontal"
      android:layout_marginBottom="8dp">

      <!-- ICCID -->
      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical"
        android:background="#141918"
        android:padding="12dp"
        android:layout_marginEnd="6dp">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/iccid"
          android:textColor="#6B7573"
          android:textSize="11sp"
          android:fontFamily="monospace"
          android:letterSpacing="0.2"/>

        <TextView
          android:id="@+id/tvIccid"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/slash"
          android:textColor="#E8EBE9"
          android:textSize="13sp"
          android:fontFamily="monospace"
          android:layout_marginTop="4dp"/>

      </LinearLayout>

      <!-- Stock level -->
      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#141918"
        android:padding="12dp"
        android:gravity="center">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/stock"
          android:textColor="#6B7573"
          android:textSize="11sp"
          android:fontFamily="monospace"
          android:letterSpacing="0.2"/>

        <TextView
          android:id="@+id/tvStockLevel"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/slash"
          android:textColor="#F0A500"
          android:textSize="18sp"
          android:fontFamily="monospace"
          android:textStyle="bold"
          android:layout_marginTop="2dp"/>

      </LinearLayout>

    </LinearLayout>

    <!-- ── Status ───────────────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="#141918"
      android:padding="10dp"
      android:layout_marginBottom="10dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status"
        android:textColor="#6B7573"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"/>

      <TextView
        android:id="@+id/tvSimStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/initialising"
        android:textColor="#8EC97A"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginTop="3dp"
        android:maxLines="2"/>

    </LinearLayout>

    <!-- ── Section label: DISPENSER ─────────────────────────────── -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/dispenser"
      android:textColor="#6B7573"
      android:textSize="11sp"
      android:letterSpacing="0.2"
      android:fontFamily="monospace"
      android:layout_marginBottom="6dp"/>

    <!-- READ ICCID — primary CTA -->
    <Button
      android:id="@+id/btnReadIccid"
      android:layout_width="match_parent"
      android:layout_height="50dp"
      android:text="@string/read_iccid"
      android:textColor="#0D0F0E"
      android:textSize="12sp"
      android:fontFamily="monospace"
      android:textStyle="bold"
      android:backgroundTint="#F0A500"
      android:layout_marginBottom="6dp"/>

    <!-- CHECK STOCK + DISPENSE -->
    <LinearLayout
      style="?android:attr/buttonBarStyle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="6dp">

      <Button
        android:id="@+id/btnCheckStock"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginEnd="5dp"
        android:text="@string/check_stock"
        android:textColor="#F0A500"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422" />

      <Button
        android:id="@+id/btnDispense"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginStart="5dp"
        android:text="@string/dispense"
        android:textColor="#E8EBE9"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

    </LinearLayout>

    <!-- PUSH TO GATE + FULL EJECT -->
    <LinearLayout
      style="?android:attr/buttonBarStyle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="6dp">

      <Button
        android:id="@+id/btnPushToGate"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginEnd="5dp"
        android:text="@string/push_to_gate"
        android:textColor="#E8EBE9"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422" />

      <Button
        android:id="@+id/btnEjectFull"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginStart="5dp"
        android:text="@string/full_eject"
        android:textColor="#CF6679"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

    </LinearLayout>

    <!-- RETRACT + RECYCLE -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="6dp">

      <Button
        android:id="@+id/btnRetract"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginEnd="5dp"
        android:text="@string/retract"
        android:textColor="#E8EBE9"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

      <Button
        android:id="@+id/btnRecycle"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_weight="1"
        android:layout_marginStart="5dp"
        android:text="@string/recycle"
        android:textColor="#E8EBE9"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

    </LinearLayout>

    <!-- ENABLE ENTRY + DISABLE ENTRY -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <Button
        android:id="@+id/btnEnableEntry"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:layout_marginEnd="5dp"
        android:text="@string/entry_on"
        android:textColor="#8EC97A"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

      <Button
        android:id="@+id/btnDisableEntry"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:layout_marginStart="5dp"
        android:text="@string/entry_off"
        android:textColor="#CF6679"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:backgroundTint="#1E2422"/>

    </LinearLayout>

    <!-- Spacer + Back -->
    <View
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_weight="1"
      tools:ignore="NestedWeights" />

    <Button
      android:id="@+id/btnSimBack"
      android:layout_width="match_parent"
      android:layout_height="40dp"
      android:text="← BACK"
      android:textColor="#6B7573"
      android:textSize="11sp"
      android:fontFamily="monospace"
      android:backgroundTint="#0D0F0E"
      android:onClick="finish"/>

  </LinearLayout>

  <!-- Divider -->
  <View
    android:layout_width="1dp"
    android:layout_height="match_parent"
    android:background="#1E2422"/>

  <!-- ═══════════════════════════════════════════════════════════════
       RIGHT PANEL — IC chip + device queries + log
       ═══════════════════════════════════════════════════════════════ -->
  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- ── Section: IC CHIP ─────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:paddingBottom="8dp">

      <View
        android:layout_width="4dp"
        android:layout_height="18dp"
        android:background="#F0A500"
        android:layout_marginEnd="8dp"/>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IC CHIP"
        android:textColor="#F0A500"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- COLD RESET + WARM RESET + DEACTIVATE -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="10dp">

      <Button
        android:id="@+id/btnSimColdReset"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:layout_marginEnd="4dp"
        android:text="COLD RST"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

      <Button
        android:id="@+id/btnSimWarmReset"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:text="WARM RST"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

      <Button
        android:id="@+id/btnSimDeactivate"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:text="DEACT."
        android:textColor="#CF6679"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

    </LinearLayout>

    <!-- ── Section: DEVICE ──────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:paddingBottom="8dp">

      <View
        android:layout_width="4dp"
        android:layout_height="18dp"
        android:background="#3A7BFF"
        android:layout_marginEnd="8dp"/>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEVICE"
        android:textColor="#3A7BFF"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- STATUS + SENSORS -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="4dp">

      <Button
        android:id="@+id/btnSimQueryStatus"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginEnd="4dp"
        android:text="STATUS"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

      <Button
        android:id="@+id/btnSimQuerySensors"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:text="SENSORS"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

    </LinearLayout>

    <!-- SERIAL + CONFIG + FIRMWARE -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginBottom="10dp">

      <Button
        android:id="@+id/btnSimSerialNumber"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginEnd="4dp"
        android:text="SERIAL"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

      <Button
        android:id="@+id/btnSimDeviceConfig"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:text="CONFIG"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

      <Button
        android:id="@+id/btnSimFirmware"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:text="FIRMWARE"
        android:textColor="#E8EBE9"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"/>

    </LinearLayout>

    <!-- ── Section: LOG ─────────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="6dp">

      <View
        android:layout_width="4dp"
        android:layout_height="18dp"
        android:background="#3A7BFF"
        android:layout_marginEnd="8dp"/>

      <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="COMMAND LOG"
        android:textColor="#3A7BFF"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"/>

      <Button
        android:id="@+id/btnSimClearLog"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:text="CLEAR"
        android:textColor="#6B7573"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:backgroundTint="#141918"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"/>

    </LinearLayout>

    <!-- Log TextView -->
    <ScrollView
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:background="#0A0C0B"
      android:padding="2dp">

      <TextView
        android:id="@+id/tvSimLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:textColor="#8EC97A"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:lineSpacingMultiplier="1.3"/>

    </ScrollView>

  </LinearLayout>

</LinearLayout>